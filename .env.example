# dbgold 后端环境变量配置示例
# 复制本文件为 .env，按需修改。.env 会在启动时自动加载（已被 .gitignore 忽略）。
# 优先级：真实环境变量（systemd/容器注入） > .env 文件 > 代码默认值。
# 未设置的项使用注释中标注的默认值，只需填写要覆盖的项。

# ── 服务 ──
APP_ENV=development               # 生产部署设为 production
LISTEN_HOST=0.0.0.0               # 监听所有 IPv4 网卡
PORT=18089                        # 服务端口（部署默认 18089）
STATIC_DIR=frontend/dist          # 前端构建产物目录
TRUSTED_PROXIES=                  # HTTPS 网关 IP/CIDR，多个值用逗号分隔

# ── 数据存储 ──
SQLITE_PATH=dbgold.db              # SQLite 文件路径（默认 dbgold.db）

# ── 认证 / JWT ──
JWT_SECRET=change-me-in-production # JWT 签名密钥（默认 change-me-in-production，生产务必改为强随机值）
JWT_EXPIRE_HOURS=240               # JWT 过期时间，单位小时（默认 240 = 10 天）
ADMIN_USER=admin                   # 初始管理员用户名（默认 admin）
ADMIN_PASS=Admin@123               # 初始管理员密码（默认 Admin@123）

# ── 日志 ──
LOG_DIR=log                        # 日志目录（默认 log）
LOG_LEVEL=info                     # 日志级别 debug/info/warn/error（默认 info）
LOG_MAX_FILES=7                    # 最多保留的日志文件数（默认 7）
LOG_MAX_TOTAL_MB=2048              # 日志总量上限，单位 MB（默认 2048 = 2GB）

# ── 工单文件上传 ──
UPLOAD_DIR=uploads                 # 上传文件落盘目录（默认 uploads）
MAX_UPLOAD_BYTES=53687091200       # 单文件大小上限，单位字节（默认 50GB）
